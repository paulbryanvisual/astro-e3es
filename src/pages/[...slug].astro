---
import Layout from '../layouts/Layout.astro';
import { getPages, getServices, optimizeHtmlImages } from '../lib/wordpress';

export async function getStaticPaths() {
  const [pages, services] = await Promise.all([getPages(), getServices()]);
  
  const pagePaths = pages.map((page: any) => {
    try {
      const url = new URL(page.link);
      const path = url.pathname.replace(/^\/|\/$/g, '');
      
      // Skip the homepage and other reserved single pages that have their own astro templates
      if (!path || path === 'home' || path === 'clients') {
        return null;
      }
      
      return {
        params: { slug: path },
        props: { page }
      };
    } catch (e) {
      // Fallback to simple slug if link parsing fails
      if (!page.slug || page.slug === 'home' || page.slug === 'clients') {
        return null;
      }
      return {
        params: { slug: page.slug },
        props: { page }
      };
    }
  }).filter(Boolean);

  const servicePaths = services.map((service: any) => {
    try {
      const url = new URL(service.link);
      const path = url.pathname.replace(/^\/|\/$/g, '');
      
      if (!path) {
        return null;
      }
      
      return {
        params: { slug: path },
        props: { page: service }
      };
    } catch (e) {
      if (!service.slug) {
        return null;
      }
      const fallbackSlug = `services/${service.slug}`;
      return {
        params: { slug: fallbackSlug },
        props: { page: service }
      };
    }
  }).filter(Boolean);

  return [...pagePaths, ...servicePaths];
}

const { page } = Astro.props;
const optimizedContent = optimizeHtmlImages(page.content.rendered);

// Get featured image if exists
let bgImage = "/images/png-1920x1080-1920x1080-1920x1080-1920x1080-1920x1080-1920x1080.jpg";
if (page._embedded && page._embedded['wp:featuredmedia'] && page._embedded['wp:featuredmedia'][0]) {
    bgImage = page._embedded['wp:featuredmedia'][0].source_url;
}
---

<Layout>
    <!-- Intro Banner -->
    <section class="db-page-hero" style={`background-image: linear-gradient(rgba(14, 53, 27, 0.7), rgba(14, 53, 27, 0.7)), url('${bgImage}');`}>
        <div class="db-page-hero__container">
            <h1 class="db-page-hero__title" set:html={page.title.rendered}></h1>
            {page.excerpt && page.excerpt.rendered && (
                <div class="db-page-hero__intro" set:html={page.excerpt.rendered}></div>
            )}
        </div>
    </section>

    <!-- Main Content -->
    <main class="services" style="padding: 6rem 2rem; background: var(--color-bg-white);">
        <div class="services__container" style="max-width: 1200px; margin: 0 auto; font-size: 1.15rem; line-height: 1.8;">
            <div set:html={optimizedContent} />
        </div>
    </main>
</Layout>
