---
import { Picture } from 'astro:assets';
import logoImage from '../assets/images/new-logo-300x115-300x115-300x115-300x115-300x115-300x115.png';
---
<header class="header">
    <div class="header__container">
        <div class="header__logo">
            <a href="/" class="mockup-clickable">
                <Picture src={logoImage} alt="E3 Entegral Solutions Logo" class="header__logo-img" widths={[150, 300]} sizes="(max-width: 768px) 150px, 300px" formats={['avif', 'webp']} loading="eager" fetchpriority="high" />
            </a>
        </div>
        <nav class="header__nav">
            <div class="header__dropdown">
                <a href="#" class="header__nav-link" style="display: flex; align-items: center; gap: 4px;">Solutions for... <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></a>
                <div class="header__dropdown-menu">
                    <a href="/k12" class="header__dropdown-item mockup-clickable">K-12 Schools</a>
                    <a href="#" class="header__dropdown-item">Municipal</a>
                    <a href="#" class="header__dropdown-item">Healthcare</a>
                    <a href="#" class="header__dropdown-item">Higher Education</a>
                </div>
            </div>
            <div class="header__dropdown">
                <a href="#" class="header__nav-link" style="display: flex; align-items: center; gap: 4px;">Our Approach <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></a>
                <div class="header__dropdown-menu">
                    <a href="/design-build" class="header__dropdown-item mockup-clickable">Design+Build</a>
                    <a href="/funding" class="header__dropdown-item mockup-clickable">Partners in Funding</a>
                </div>
            </div>
            <a href="/clients" class="header__nav-link mockup-clickable">Clients</a>
            <a href="/services" class="header__nav-link mockup-clickable">Services</a>
            <div class="header__dropdown">
                <a href="#" class="header__nav-link" style="display: flex; align-items: center; gap: 4px;">About Us <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></a>
                <div class="header__dropdown-menu">
                    <a href="#" class="header__dropdown-item">Our Story</a>
                    <a href="#" class="header__dropdown-item">Our Team</a>
                    <a href="#" class="header__dropdown-item">Contact</a>
                </div>
            </div>
            <div class="header__contact-wrapper">
                <a href="#" class="header__btn btn btn--primary" id="getStartedBtn">Get Started</a>
                <div class="header__contact-dropdown" id="contactDropdown">
                    <h3 class="contact-dropdown__title">Let's Connect</h3>
                    <p class="contact-dropdown__subtitle">Reach out to our experts to discuss your facility needs and explore funding options.</p>
                    
                    <div class="contact-dropdown__grid">
                        <div class="contact-dropdown__col">
                            <h4>Direct Contact</h4>
                            <ul>
                                <li><a href="tel:+18005550199"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary-green)"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg> (800) 555-0199</a></li>
                                <li><a href="mailto:info@e3es.com"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary-green)"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg> info@e3es.com</a></li>
                                <li><a href="#"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary-green)"><rect x="3" y="4" width="18" height="18" rx="0" ry="0"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg> Schedule a Consultation</a></li>
                            </ul>
                        </div>
                        <div class="contact-dropdown__col">
                            <h4>Regional Experts</h4>
                            <ul>
                                <li><a href="/south-texas" class="mockup-clickable"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary-green)"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg> South Texas (Bill)</a></li>
                                <li><a href="#"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary-green)"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg> North Texas</a></li>
                                <li><a href="#"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary-green)"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg> Central Texas</a></li>
                            </ul>
                        </div>
                    </div>
                    <div class="contact-dropdown__footer">
                        <h4>Texas Office Locations</h4>
                        <p>Dallas | Houston | Austin | San Antonio</p>
                    </div>
                </div>
            </div>
        </nav>
    </div>
</header>
<script>
    const getStartedBtn = document.getElementById('getStartedBtn');
    const contactDropdown = document.getElementById('contactDropdown');
    
    if (getStartedBtn && contactDropdown) {
        getStartedBtn.addEventListener('click', (e) => {
            e.preventDefault();
            contactDropdown.classList.toggle('active');
        });
        
        document.addEventListener('click', (e) => {
            if (!getStartedBtn.contains(e.target as Node) && !contactDropdown.contains(e.target as Node)) {
                contactDropdown.classList.remove('active');
            }
        });
    }
</script>
